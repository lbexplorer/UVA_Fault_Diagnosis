# Ignore everything by default
*

# Keep Git metadata and this ignore file
!.gitignore

# Never publish project-specific SSH keys
.git-ssh/

# Keep the dataset we want to publish
!datasets/
!datasets/BASiC/
!datasets/BASiC/small_data_analysis_pack/
!datasets/BASiC/small_data_analysis_pack/**

# Keep experiment outputs for result tracking
!outputs/
!outputs/**

# Keep training scripts for version control
!uav_fault_detection_binary.py
!uav_fault_new_method_v2.py
!uav_fault_tree_baseline.py

# Optional project note
!README.md
